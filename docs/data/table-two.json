  {
    "tbody": [
      {
        "row": [
          {
            "column": "<b>onSearch</b>: ({ currentValue, element }) => {}"
          },
          { "column": "&check;" },
          {
            "column": "Function for user input. It can be a synchronous function or a promise"
          }
        ]
      },
      {
        "row": [
          {
            "column": "<b>onResults</b>: ({ currentValue, matches, classGroup }) => {}"
          },
          { "column": "&check;" },
          {
            "column": "Renders the result list. <code>matches</code> is always an array. When no results are found, <code>noResults</code> is called instead."
          }
        ]
      },
      {
        "row": [
          { "column": "<b>onRender</b>: ({ element, results }) => {}" },
          { "column": "" },
          {
            "column": "When we want to add additional elements, e.g. some buttons or plain text. See the <code><a href=\"#footer-example\">Footer/Header</a></code> example. This function is only called once."
          }
        ]
      },
      {
        "row": [
          {
            "column": "<b>onSubmit</b>: ({ index, element, object, results }) => {}"
          },
          { "column": "" },
          {
            "column": "Executed on input submission"
          }
        ]
      },
      {
        "row": [
          { "column": "<b>onOpened</b>: ({ type, element, results }) => {}" },
          { "column": "" },
          {
            "column": "Returns two variables <code>results</code> and <code>showItems</code>. <br><code>resutls</code> first rendering of the results <code>showItems</code> only showing the results when clicking on the input field"
          }
        ]
      },
      {
        "row": [
          {
            "column": "<b>onSelectedItem</b>: ({ index, element, object, currentValue }) => {}"
          },
          { "column": "" },
          {
            "column": "Get index and data from li element after hovering over li with the mouse or using arrow keys <kbd>↓</kbd> or <kbd>↑</kbd>"
          }
        ]
      },
      {
        "row": [
          { "column": "<b>onReset</b>: (element) => {}" },
          { "column": "" },
          {
            "column": "After clicking the <kbd>x</kbd> button"
          }
        ]
      },
      {
        "row": [
          { "column": "<b>onClose</b>: () => {}" },
          { "column": "" },
          {
            "column": "e.g. remove class after closing results. See an example of modal"
          }
        ]
      },
      {
        "row": [
          {
            "column": "<b>noResults</b>: ({ element, currentValue }) => {}"
          },
          { "column": "" },
          {
            "column": "Called when no results are found. Return an HTML string to display, e.g. <code>noResults: ({ currentValue }) => `&lt;li&gt;No results for \"${currentValue}\"&lt;/li&gt;`</code>"
          }
        ]
      }
    ]
